{
  "name": "giftan-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "fastify": "4.29.1"
  },
  "scripts": {
    "dev:frontend": "npm run dev -w @giftan/frontend",
    "dev:backend": "npm run start:dev -w @giftan/backend",
    "db:generate": "npm run generate -w @giftan/backend",
    "db:migrate": "npm run migrate -w @giftan/backend",
    "db:push": "npm run push -w @giftan/backend"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "mercurius": "^16.9.0",
    "next-auth": "3.29.10"
  },
  "devDependencies": {
    "drizzle-kit": "^0.18.1"
  }
}
